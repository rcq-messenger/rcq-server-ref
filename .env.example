# RCQ backend — example environment.
# Copy to `.env` next to this file (or supply via your process supervisor)
# and fill in the values that matter for your deployment.

# ── App ──────────────────────────────────────────────────────────────
APP_NAME=RCQ Backend
# Free-form environment tag. Used in logs only; production deployments
# usually set this to "prod".
ENV=dev

# ── Datastores ───────────────────────────────────────────────────────
# Postgres (recommended for anything beyond a single-user playground):
#   DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME
# SQLite (default — fine for local development, NOT recommended for
# multi-worker uvicorn since SQLite serializes writes):
DATABASE_URL=sqlite+aiosqlite:///./rcq.db

# Redis is required for cross-worker fan-out (WebSocket pub/sub,
# rate-limit buckets, random-chat queue, hood bucket subscribers).
# A local redis-server install + the default URL below is enough.
REDIS_URL=redis://localhost:6379/0

# ── Auth ─────────────────────────────────────────────────────────────
# REQUIRED in production. Anything cryptographically random will do
# (e.g. `openssl rand -hex 32`). The default fallback is deliberately
# garbage so misconfigured production servers fail safely loud.
JWT_SECRET=change-me-in-prod
JWT_ALG=HS256
# Token TTL in seconds. 30 days by default.
JWT_TTL_SECONDS=2592000

# ── UIN allocation ───────────────────────────────────────────────────
# Range the allocator picks from. ICQ-style 6-9 digits by default;
# self-hosters MAY narrow this if they want a smaller pool.
UIN_MIN=100000
UIN_MAX=999999999

# ── APNs push (optional) ─────────────────────────────────────────────
# Leave the key fields empty to disable push entirely. The sender
# no-ops cleanly when APNS_KEY_PATH is empty — your users will still
# receive messages on next WebSocket connect, just without iOS push
# alerts.
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
# Path inside the container / host to the .p8 file from Apple Developer.
APNS_KEY_PATH=
# "production" → api.push.apple.com (App Store / TestFlight after
# the app is on the Store). "sandbox" → api.sandbox.push.apple.com
# (TestFlight pre-Store, dev builds).
APNS_ENVIRONMENT=production

# ── TURN (optional, for WebRTC calls behind symmetric NATs) ──────────
# Leave empty to fall back to STUN-only — calls work for permissive
# networks and fail silently for stricter ones. Stand a coturn server
# up and fill these in for reliable calls.
TURN_HOST=
TURN_SECRET=
TURN_TTL_SECONDS=86400

# ── Admin panel (optional) ───────────────────────────────────────────
# Leave ADMIN_USERNAME empty to disable every /admin/* route entirely
# (the router returns 503 with a clear message). When set, the admin
# SPA + every /admin/* endpoint authenticate via HTTP Basic against
# these credentials.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ── Account-migration cooldown (optional) ────────────────────────────
# Seconds a user must wait between two /account/migrate calls. 0 (the
# default) means "always allowed" — fine for closed beta. Production
# typically wants 604800 (7 days) to stop users churning UINs to
# dodge blocks.
RCQ_MIGRATION_COOLDOWN_SECONDS=0

# ── Founder auto-add (optional, RCQ-specific demo behaviour) ─────────
# When a new account registers, the founder's UIN is added to both
# directions of the new user's contact list, and the new user is
# auto-joined to the founder's "beta" group. Set to 0 to disable on
# self-hosted deployments where there isn't one founder UIN to begin
# with.
RCQ_FOUNDER_UIN=0
RCQ_FOUNDER_BETA_GROUP_ID=0

# ── Media storage paths (optional) ───────────────────────────────────
# Filesystem locations for encrypted media blobs, news media, and
# admin moderation evidence files. Default to local subdirectories;
# point at a persistent volume for production. The blob contents are
# AES-GCM encrypted by the sender — the server never holds plaintext.
RCQ_MEDIA_DIR=./media/uploads
RCQ_NEWS_MEDIA_DIR=./news_media
RCQ_EVIDENCE_DIR=./evidence
